# ── HiAnime API – environment variables ──────────────────────────────────────
# Copy this file to .env for local development with `vercel dev`.
# On Vercel, set these via the project dashboard → Settings → Environment Variables.

# Optional: restrict CORS to specific origins (comma-separated, no spaces).
# Leave blank to allow all origins (*).
# ALLOWED_ORIGINS=https://myapp.vercel.app,https://mysite.com

# Node environment (development | production)
NODE_ENV=development
