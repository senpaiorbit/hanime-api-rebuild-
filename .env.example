# ── HiAnime API (Hono) – environment variables ───────────────────────────────

# Server port
PORT=3000

# Node environment (development | production)
NODE_ENV=development

# Redis connection (optional — caching disabled when unset)
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=

# Optional: restrict CORS to specific origins (comma-separated, no spaces).
# Leave blank to allow all origins (*).
# ALLOWED_ORIGINS=https://myapp.example.com,https://mysite.com
