{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Access-Control-Allow-Methods": "GET, OPTIONS",
        "Access-Control-Allow-Headers": "Content-Type"
      }
    }
  ],
  "functions": {
    "api/home.js":              { "runtime": "edge" },
    "api/search.js":            { "runtime": "edge" },
    "api/search-suggestion.js": { "runtime": "edge" },
    "api/anime.js":             { "runtime": "edge" },
    "api/episodes.js":          { "runtime": "edge" },
    "api/servers.js":           { "runtime": "edge" },
    "api/sources.js":           { "runtime": "edge" },
    "api/category.js":          { "runtime": "edge" },
    "api/genre.js":             { "runtime": "edge" },
    "api/producer.js":          { "runtime": "edge" },
    "api/azlist.js":            { "runtime": "edge" },
    "api/schedule.js":          { "runtime": "edge" },
    "api/qtip.js":              { "runtime": "edge" }
  }
}
